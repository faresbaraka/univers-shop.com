{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An ecommerce product for sale on Univers Shop",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "number" },
        "salesCount": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "price", "imageUrl", "category", "stock", "salesCount", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order on Univers Shop",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "transactionId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerAddress": { "type": "string" },
        "customerWilaya": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "orderStatus": { "type": "string" },
        "transactionDate": { "type": "string" },
        "receiptScreenshot": { "type": "string" },
        "cardLastFour": { "type": "string" },
        "otpVerified": { "type": "boolean" },
        "returnStatus": { "type": "string" },
        "returnReason": { "type": "string" },
        "returnDate": { "type": "string" },
        "adminReturnNotes": { "type": "string" }
      },
      "required": ["id", "transactionId", "customerName", "customerPhone", "customerAddress", "customerWilaya", "items", "totalAmount", "paymentMethod", "paymentStatus", "orderStatus", "transactionDate", "otpVerified"]
    },
    "StoreSettings": {
      "title": "StoreSettings",
      "description": "Global customization settings for the store identity",
      "type": "object",
      "properties": {
        "storeName": { "type": "string" },
        "logoUrl": { "type": "string" },
        "sellerPhone": { "type": "string" }
      },
      "required": ["storeName", "logoUrl", "sellerPhone"]
    },
    "Review": {
      "title": "Review",
      "description": "A customer review for a product or the site",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "customerName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "productId", "productName", "customerName", "rating", "comment", "createdAt"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Collection of retail items available"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of client purchases"
    },
    "settings/{settingsId}": {
      "schema": "StoreSettings",
      "description": "Collection containing global store identity document"
    },
    "reviews/{reviewId}": {
      "schema": "Review",
      "description": "Collection of product and site reviews written by customers"
    }
  }
}
