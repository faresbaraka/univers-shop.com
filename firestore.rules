rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if ID is valid format
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() < 100 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    // Product collection
    match /products/{productId} {
      allow read: if true;
      allow write: if isValidId(productId);
    }
    
    // Orders collection
    match /orders/{orderId} {
      allow read: if true;
      allow write: if isValidId(orderId);
    }
    
    // Settings collection
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isValidId(settingsId);
    }
  }
}
