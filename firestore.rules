rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if ID is valid format
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() < 100 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    // Product collection
    match /products/{productId} {
      allow read: if true;
      allow write: if isValidId(productId);
    }
    
    // Orders collection
    match /orders/{orderId} {
      allow read: if true;
      allow write: if isValidId(orderId);
    }
    
    // Settings collection
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isValidId(settingsId);
    }
    
    // Reviews collection
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isValidId(reviewId) 
        && request.resource.data.keys().hasAll(['id', 'productId', 'productName', 'customerName', 'rating', 'comment', 'createdAt'])
        && request.resource.data.keys().size() == 7
        && request.resource.data.id == reviewId
        && request.resource.data.productId is string
        && request.resource.data.productName is string && request.resource.data.productName.size() <= 200
        && request.resource.data.customerName is string && request.resource.data.customerName.size() <= 100
        && request.resource.data.rating is number && request.resource.data.rating >= 1 && request.resource.data.rating <= 5
        && request.resource.data.comment is string && request.resource.data.comment.size() <= 1000
        && request.resource.data.createdAt is string;
      allow update, delete: if false; // Reviews are immutable
    }
  }
}
